# Copy to `.env` (gitignored) and fill in the secrets. Foundry auto-loads `.env`
# when you run `forge script` from the contracts/ directory.

# --- Deployer ---------------------------------------------------------------
# Throwaway TESTNET key only. Fund its address with Arc testnet USDC (gas) from
# the Arc faucet; add Sepolia ETH too if you deploy the CCIP relay sentinel.
DEPLOYER_PRIVATE_KEY=

# --- RPC endpoints (referenced by foundry.toml [rpc_endpoints]) --------------
ARC_RPC_URL=https://rpc.testnet.arc.network
SEPOLIA_RPC_URL=

# --- Arc testnet: collateral + CCIP (verified addresses) --------------------
USDC_ADDRESS=0x3600000000000000000000000000000000000000
# Set CCIP_ROUTER to also deploy the CCIP-relayed market in Deploy.s.sol.
CCIP_ROUTER=0xdE4E7FED43FAC37EB21aA0643d9852f75332eab8

# --- CCIP relay: Sepolia (source) -> Arc (dest) -----------------------------
SOURCE_ROUTER=0x0BF3dE8c5D3e8A2B34D2BEeB17ABfCeBaf363A59
ARC_SELECTOR=3034092155422581607
# SOURCE_FEED = the USDe/USD source on Sepolia. There is NO real USDe feed on
# any testnet, so deploy a MockV3Aggregator on Sepolia (it represents USDe/USD;
# in production this same setup points at the real mainnet USDe feed) and put
# its address here.
SOURCE_FEED=
# RELAYED_FEED = read from contracts/deployments.json after the Arc deploy.
RELAYED_FEED=
